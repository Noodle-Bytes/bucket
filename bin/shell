set -euo pipefail

# Check for BUCKET_ROOT already being set in the shell
if [[ -n "${BUCKET_ROOT:-}" ]]; then
    echo "[\033[0;31mERROR\033[0m] Bucket shell is already activated!"
    exit 1
fi

# Work out where the repository is located (portable: no readlink -f).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
BUCKET_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"

if [[ -z "${BUCKET_ROOT:-}" ]]; then
    echo "[\033[0;31mERROR\033[0m] Could not determine BUCKET_ROOT."
    exit 1
fi

case "$(uname -s)" in
    MINGW*|MSYS*|CYGWIN*)
        USER_HOME_WIN="${USERPROFILE:-$HOME}"
        USER_HOME_POSIX="$(cygpath -u "$USER_HOME_WIN" 2>/dev/null || echo "$HOME")"
        if [[ -d "$USER_HOME_POSIX/.local/bin" ]]; then
            export PATH="$USER_HOME_POSIX/.local/bin:$PATH"
        fi
        if [[ -d "/c/Program Files/nodejs" ]]; then
            export PATH="/c/Program Files/nodejs:$PATH"
        fi
        ;;
esac

ZDOTDIR=$BUCKET_ROOT/bin/zsh
if [[ ! -d "$ZDOTDIR" ]]; then
    echo "[\033[0;31mERROR\033[0m] ZDOTDIR not found: $ZDOTDIR"
    exit 1
fi

SHELL_BIN="$(command -v zsh || true)"
SHELL_NAME="zsh"
if [[ -z "$SHELL_BIN" ]]; then
    SHELL_BIN="$(command -v bash || true)"
    SHELL_NAME="bash"
fi

if [[ -z "$SHELL_BIN" ]]; then
    echo "[\033[0;31mERROR\033[0m] zsh or bash is required for ./bin/shell but neither was found."
    echo "On Windows PowerShell, run: .\\bin\\shell.ps1"
    exit 1
fi

USER_HISTFILE=${HISTFILE:-$HOME/.zsh_history}

if [[ "$SHELL_NAME" == "zsh" ]]; then
    BUCKET_ROOT=$BUCKET_ROOT \
        USER_HISTFILE=$USER_HISTFILE \
        ZDOTDIR=$ZDOTDIR \
        "$SHELL_BIN" -i "$@"
else
    BASH_ENV_FILE="$BUCKET_ROOT/bin/bash/.bashrc"
    if [[ ! -f "$BASH_ENV_FILE" ]]; then
        echo "[\033[0;31mERROR\033[0m] Bash environment file not found: $BASH_ENV_FILE"
        exit 1
    fi
    if [[ "$#" -gt 0 ]]; then
        BUCKET_ROOT=$BUCKET_ROOT \
            USER_HISTFILE=${HISTFILE:-$HOME/.bash_history} \
            bash --rcfile "$BASH_ENV_FILE" -i -c "$*"
    else
        BUCKET_ROOT=$BUCKET_ROOT \
            USER_HISTFILE=${HISTFILE:-$HOME/.bash_history} \
            bash --rcfile "$BASH_ENV_FILE" -i
    fi
fi
