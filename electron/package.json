{
  "name": "bucket-electron",
  "version": "2.3.3",
  "description": "Bucket Coverage Viewer - Mac App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "dev": "NODE_ENV=development electron ."
  },
  "author": "Noodle-Bytes",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.noodlebytes.bucket",
    "productName": "Bucket",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "bucket.icns",
      "extendInfo": {
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.noodlebytes.bktgz",
            "UTTypeDescription": "Bucket Coverage Archive",
            "UTTypeIconFile": "bucket_file.icns",
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "bktgz"
              ],
              "public.mime-type": [
                "application/x-bktgz"
              ]
            },
            "UTTypeConformsTo": [
              "public.data"
            ]
          }
        ]
      },
      "fileAssociations": [
        {
          "ext": "bktgz",
          "name": "Bucket Archive",
          "role": "Viewer",
          "rank": "Owner",
          "icon": "bucket_file.icns"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../viewer/dist",
        "to": "viewer/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "."
    }
  }
}
