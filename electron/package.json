{
  "name": "bucket-electron",
  "version": "2.2.0",
  "description": "Bucket Coverage Viewer - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux AppImage deb",
    "build:win": "electron-builder --win nsis",
    "smoke": "node smoke.js",
    "dev": "electron ."
  },
  "author": "Noodle-Bytes",
  "license": "MIT",
  "dependencies": {
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.noodlebytes.bucket",
    "productName": "Bucket",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "../viewer/public/pwa-512x512.png",
      "extendInfo": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Bucket Archive",
            "CFBundleTypeRole": "Viewer",
            "CFBundleTypeIconFile": "pwa-512x512.png",
            "LSItemContentTypes": [
              "com.noodlebytes.bktgz"
            ],
            "LSHandlerRank": "Owner"
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.noodlebytes.bktgz",
            "UTTypeDescription": "Bucket Coverage Archive",
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "bktgz"
              ],
              "public.mime-type": [
                "application/gzip"
              ]
            }
          }
        ]
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "packElevateHelper": false
    },
    "linux": {
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "fileAssociations": [
      {
        "ext": "bktgz",
        "name": "Bucket Coverage Archive",
        "description": "Bucket coverage archive file",
        "role": "Viewer",
        "mimeType": "application/gzip"
      }
    ],
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../viewer/dist",
        "to": "viewer/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "."
    }
  }
}
